{
	"name": "backlog-drift",
	"version": "0.1.0",
	"description": "AI-powered drift detection for Backlog.md",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"backlog-drift": "src/index.ts"
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"test": "bun test",
		"check": "biome check src/",
		"check:fix": "biome check --write src/",
		"check:types": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ReliableGenius/backlog.md-drift.git"
	},
	"author": "",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/ReliableGenius/backlog.md-drift/issues"
	},
	"homepage": "https://github.com/ReliableGenius/backlog.md-drift#readme",
	"dependencies": {
		"commander": "^13.1.0",
		"gray-matter": "^4.0.3",
		"picocolors": "^1.1.1",
		"simple-git": "^3.27.0",
		"yaml": "^2.7.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "^1.2.5",
		"bun-types": "^1.2.5",
		"typescript": "^5.7.3"
	}
}
